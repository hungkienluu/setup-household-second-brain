<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.household.brain-listener</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{VAULT_ROOT}}/scripts/household-runner</string>
        <string>webhook_listener.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>{{VAULT_ROOT}}/logs/brain-listener.log</string>
    <key>StandardErrorPath</key>
    <string>{{VAULT_ROOT}}/logs/brain-listener.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
        <key>USER</key>
        <string>{{RUNTIME_USER}}</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:{{GEMINI_BIN_DIR}}</string>
        <key>VAULT_ROOT</key>
        <string>{{VAULT_ROOT}}</string>
    </dict>
</dict>
</plist>